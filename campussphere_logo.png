<svg width="100%" viewBox="0 0 680 480" role="img" xmlns="http://www.w3.org/2000/svg">
<title style="fill:rgb(0, 0, 0);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto">CampusSphere logo</title>
<desc style="fill:rgb(0, 0, 0);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto">A professional purple and lavender logo for CampusSphere, featuring a stylized sphere with orbital rings and a clean wordmark.</desc>

<defs>
  <linearGradient id="sphereGrad" x1="0%" y1="0%" x2="100%" y2="100%">
    <stop offset="0%" style="stop-color:#c4b5fd"/>
    <stop offset="50%" style="stop-color:#8b5cf6"/>
    <stop offset="100%" style="stop-color:#5b21b6"/>
  </linearGradient>
  <linearGradient id="ringGrad1" x1="0%" y1="0%" x2="100%" y2="0%">
    <stop offset="0%" style="stop-color:#ddd6fe;stop-opacity:0.15"/>
    <stop offset="40%" style="stop-color:#a78bfa;stop-opacity:0.85"/>
    <stop offset="60%" style="stop-color:#a78bfa;stop-opacity:0.85"/>
    <stop offset="100%" style="stop-color:#ddd6fe;stop-opacity:0.15"/>
  </linearGradient>
  <linearGradient id="ringGrad2" x1="0%" y1="0%" x2="100%" y2="0%">
    <stop offset="0%" style="stop-color:#ede9fe;stop-opacity:0.1"/>
    <stop offset="40%" style="stop-color:#c4b5fd;stop-opacity:0.6"/>
    <stop offset="60%" style="stop-color:#c4b5fd;stop-opacity:0.6"/>
    <stop offset="100%" style="stop-color:#ede9fe;stop-opacity:0.1"/>
  </linearGradient>
  <linearGradient id="shimmer" x1="30%" y1="20%" x2="70%" y2="80%">
    <stop offset="0%" style="stop-color:#ede9fe;stop-opacity:0.55"/>
    <stop offset="100%" style="stop-color:#7c3aed;stop-opacity:0"/>
  </linearGradient>
  <radialGradient id="glowBg" cx="50%" cy="50%" r="50%">
    <stop offset="0%" style="stop-color:#7c3aed;stop-opacity:0.12"/>
    <stop offset="100%" style="stop-color:#7c3aed;stop-opacity:0"/>
  </radialGradient>
  <clipPath id="sphereClip">
    <circle cx="240" cy="220" r="88"/>
  </clipPath>
</defs>

<!-- Ambient glow behind sphere -->
<ellipse cx="240" cy="222" rx="130" ry="120" fill="url(#glowBg)" style="stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

<!-- ── Orbital rings (back, behind sphere) ── -->
<!-- Ring 1 back half -->
<ellipse cx="240" cy="220" rx="132" ry="34" fill="none" stroke="url(#ringGrad1)" stroke-width="2.2" stroke-dasharray="414" stroke-dashoffset="207" transform="rotate(-18 240 220)" style="fill:none;color:rgb(255, 255, 255);stroke-width:2.2px;stroke-dasharray:414px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

<!-- Ring 2 back half -->
<ellipse cx="240" cy="220" rx="112" ry="24" fill="none" stroke="url(#ringGrad2)" stroke-width="1.5" stroke-dasharray="352" stroke-dashoffset="176" transform="rotate(22 240 220)" style="fill:none;color:rgb(255, 255, 255);stroke-width:1.5px;stroke-dasharray:352px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

<!-- ── Main sphere body ── -->
<circle cx="240" cy="220" r="88" fill="url(#sphereGrad)" style="stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

<!-- Sphere surface detail — latitude lines -->
<ellipse cx="240" cy="220" rx="88" ry="26" fill="none" stroke="#ede9fe" stroke-width="0.8" stroke-opacity="0.25" clip-path="url(#sphereClip)" style="fill:none;stroke:rgb(237, 233, 254);color:rgb(255, 255, 255);stroke-width:0.8px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
<ellipse cx="240" cy="195" rx="88" ry="18" fill="none" stroke="#ede9fe" stroke-width="0.8" stroke-opacity="0.18" clip-path="url(#sphereClip)" style="fill:none;stroke:rgb(237, 233, 254);color:rgb(255, 255, 255);stroke-width:0.8px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
<ellipse cx="240" cy="245" rx="88" ry="18" fill="none" stroke="#ede9fe" stroke-width="0.8" stroke-opacity="0.18" clip-path="url(#sphereClip)" style="fill:none;stroke:rgb(237, 233, 254);color:rgb(255, 255, 255);stroke-width:0.8px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

<!-- Sphere surface — vertical meridian -->
<line x1="240" y1="132" x2="240" y2="308" stroke="#ede9fe" stroke-width="0.8" stroke-opacity="0.2" clip-path="url(#sphereClip)" style="fill:rgb(0, 0, 0);stroke:rgb(237, 233, 254);color:rgb(255, 255, 255);stroke-width:0.8px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

<!-- Sphere highlight shimmer -->
<ellipse cx="210" cy="185" rx="38" ry="26" fill="url(#shimmer)" clip-path="url(#sphereClip)" style="stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

<!-- Small highlight dot -->
<circle cx="200" cy="177" r="7" fill="#ede9fe" fill-opacity="0.35" clip-path="url(#sphereClip)" style="fill:rgb(237, 233, 254);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

<!-- ── Orbital rings (front, over sphere) ── -->
<!-- Ring 1 front half -->
<ellipse cx="240" cy="220" rx="132" ry="34" fill="none" stroke="url(#ringGrad1)" stroke-width="2.2" stroke-dasharray="414" stroke-dashoffset="-207" transform="rotate(-18 240 220)" style="fill:none;color:rgb(255, 255, 255);stroke-width:2.2px;stroke-dasharray:414px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

<!-- Ring 2 front half -->
<ellipse cx="240" cy="220" rx="112" ry="24" fill="none" stroke="url(#ringGrad2)" stroke-width="1.5" stroke-dasharray="352" stroke-dashoffset="-176" transform="rotate(22 240 220)" style="fill:none;color:rgb(255, 255, 255);stroke-width:1.5px;stroke-dasharray:352px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

<!-- ── Orbit dot accents ── -->
<circle cx="355" cy="196" r="5.5" fill="#c4b5fd" style="fill:rgb(196, 181, 253);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
<circle cx="125" cy="244" r="4" fill="#ddd6fe" fill-opacity="0.7" style="fill:rgb(221, 214, 254);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
<circle cx="298" cy="316" r="3.5" fill="#a78bfa" fill-opacity="0.8" style="fill:rgb(167, 139, 250);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
<circle cx="316" cy="176" r="3" fill="#ede9fe" fill-opacity="0.6" style="fill:rgb(237, 233, 254);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
<circle cx="163" cy="161" r="3" fill="#c4b5fd" fill-opacity="0.6" style="fill:rgb(196, 181, 253);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

<!-- ── Connection node dots on sphere surface ── -->
<circle cx="240" cy="148" r="4.5" fill="#ede9fe" fill-opacity="0.8" style="fill:rgb(237, 233, 254);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
<circle cx="316" cy="220" r="4" fill="#ddd6fe" fill-opacity="0.6" style="fill:rgb(221, 214, 254);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
<circle cx="165" cy="220" r="4" fill="#ddd6fe" fill-opacity="0.6" style="fill:rgb(221, 214, 254);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
<circle cx="240" cy="292" r="4.5" fill="#ede9fe" fill-opacity="0.6" style="fill:rgb(237, 233, 254);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

<!-- subtle connector lines on sphere -->
<line x1="240" y1="152" x2="313" y2="221" stroke="#ddd6fe" stroke-width="0.7" stroke-opacity="0.28" clip-path="url(#sphereClip)" style="fill:rgb(0, 0, 0);stroke:rgb(221, 214, 254);color:rgb(255, 255, 255);stroke-width:0.7px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
<line x1="240" y1="152" x2="168" y2="221" stroke="#ddd6fe" stroke-width="0.7" stroke-opacity="0.28" clip-path="url(#sphereClip)" style="fill:rgb(0, 0, 0);stroke:rgb(221, 214, 254);color:rgb(255, 255, 255);stroke-width:0.7px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
<line x1="313" y1="221" x2="240" y2="289" stroke="#ddd6fe" stroke-width="0.7" stroke-opacity="0.28" clip-path="url(#sphereClip)" style="fill:rgb(0, 0, 0);stroke:rgb(221, 214, 254);color:rgb(255, 255, 255);stroke-width:0.7px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
<line x1="168" y1="221" x2="240" y2="289" stroke="#ddd6fe" stroke-width="0.7" stroke-opacity="0.28" clip-path="url(#sphereClip)" style="fill:rgb(0, 0, 0);stroke:rgb(221, 214, 254);color:rgb(255, 255, 255);stroke-width:0.7px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

<!-- ══════════════════
     WORDMARK
══════════════════ -->

<!-- "Campus" -->
<text x="352" y="204" font-family="Georgia, 'Times New Roman', serif" font-size="46" font-weight="700" letter-spacing="-1" fill="#4c1d95" style="fill:rgb(76, 29, 149);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Georgia, &quot;Times New Roman&quot;, serif;font-size:46px;font-weight:700;text-anchor:start;dominant-baseline:auto">Campus</text>

<!-- "Sphere" — lighter weight, lavender -->
<text x="352" y="252" font-family="Georgia, 'Times New Roman', serif" font-size="46" font-weight="400" letter-spacing="-1" fill="#7c3aed" style="fill:rgb(124, 58, 237);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Georgia, &quot;Times New Roman&quot;, serif;font-size:46px;font-weight:400;text-anchor:start;dominant-baseline:auto">Sphere</text>

<!-- Tagline -->
<text x="354" y="278" font-family="Georgia, 'Times New Roman', serif" font-size="13" font-weight="400" letter-spacing="3.5" fill="#a78bfa" style="fill:rgb(167, 139, 250);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Georgia, &quot;Times New Roman&quot;, serif;font-size:13px;font-weight:400;text-anchor:start;dominant-baseline:auto">CONNECT · COLLABORATE · GROW</text>

<!-- ── Horizontal rule under tagline ── -->
<line x1="352" y1="291" x2="620" y2="291" stroke="#c4b5fd" stroke-width="1" stroke-opacity="0.5" style="fill:rgb(0, 0, 0);stroke:rgb(196, 181, 253);color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

<!-- ── Small dot accent left of wordmark ── -->
<circle cx="344" cy="210" r="3.5" fill="#8b5cf6" style="fill:rgb(139, 92, 246);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
<circle cx="344" cy="245" r="3.5" fill="#a78bfa" style="fill:rgb(167, 139, 250);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

<!-- ══════════════════
     BOTTOM LOCKUP — Icon-only version label
══════════════════ -->
<text x="340" y="430" font-family="Georgia, 'Times New Roman', serif" font-size="11.5" font-weight="400" letter-spacing="2" fill="#c4b5fd" text-anchor="middle" style="fill:rgb(196, 181, 253);stroke:none;color:rgb(255, 255, 255);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Georgia, &quot;Times New Roman&quot;, serif;font-size:11.5px;font-weight:400;text-anchor:middle;dominant-baseline:auto">campus social &amp; activity platform</text>

<!-- Bottom accent line group -->
<line x1="180" y1="440" x2="500" y2="440" stroke="#7c3aed" stroke-width="0.8" stroke-opacity="0.3" style="fill:rgb(0, 0, 0);stroke:rgb(124, 58, 237);color:rgb(255, 255, 255);stroke-width:0.8px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:&quot;Anthropic Sans&quot;, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

</svg>